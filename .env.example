# Discord Bot
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/bugsnitch

# Encryption (32 bytes = 64 hex characters, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=generate_a_64_char_hex_string_here

# Webhook Server
PORT=3000
WEBHOOK_BASE_URL=https://bugsnitch.yourdomain.com

# Logging (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info
